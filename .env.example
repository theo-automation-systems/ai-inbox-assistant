# LLM provider: groq (default, recommended) or openai
LLM_PROVIDER=groq

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here
# Examples: llama-3.3-70b-versatile, llama-3.1-8b-instant (often more headroom on free tiers)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — only if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Fake emails directory (paths relative to project root)
EMAILS_DIR=emails

# FastAPI host / port
API_HOST=0.0.0.0
API_PORT=8000

# Allowed origins for Streamlit (CSV)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# LLM reliability
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# Backend URL as seen by Streamlit (adjust if tunnel or different port)
STREAMLIT_API_BASE=http://127.0.0.1:8000
